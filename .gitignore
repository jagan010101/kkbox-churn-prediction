# Data size runs into multiple GBs - ignore contents, keep folder structure
data/raw/*
data/processed/*

# Keep the small, human-readable feature manifest
!data/processed/feature_manifest.json

# Keep empty data folders visible in git
!data/raw/.gitkeep
!data/processed/.gitkeep

# Jupyter / Python
.ipynb_checkpoints/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# OS
.DS_Store
__MACOSX/

# CatBoost's auto-generated per-run training log directory
catboost_info/

# Optuna study storage (Phase 5) - large, regenerable
*.db

# run_pipeline.sh's timestamped log files - regenerable, not source
pipeline_run_*.log

# Editor/tooling
.claude/
.tmp/
